# OneBot
# OneBot HTTP API 基础地址（用于发送回复与动作调用）。
ONEBOT_HTTP_BASE=http://127.0.0.1:3000
# OneBot WS 地址（用于接收入站事件）。
ONEBOT_WS_URL=ws://127.0.0.1:3001
# OneBot 访问令牌（Authorization: Bearer ...）。
ONEBOT_ACCESS_TOKEN=__ONEBOT_ACCESS_TOKEN__

# OpenClaw Gateway
# OpenClaw Gateway WS 地址。
OPENCLAW_WS_URL=ws://127.0.0.1:18789
# Gateway 鉴权 token/password（按你的部署可只用其一或同时使用）。
OPENCLAW_GATEWAY_TOKEN=__OPENCLAW_GATEWAY_TOKEN__
OPENCLAW_GATEWAY_PASSWORD=
# Gateway 连接握手时上报的 bridge 客户端身份信息。
OPENCLAW_CLIENT_ID=gateway-client
OPENCLAW_CLIENT_MODE=backend
OPENCLAW_ROLE=operator
# Gateway scopes，逗号分隔。
OPENCLAW_SCOPES=operator.read,operator.write
# 单次 OpenClaw 请求超时（秒）。
OPENCLAW_TIMEOUT_SEC=180
# bridge 生成 OpenClaw 会话 key 时使用的前缀。
OPENCLAW_SESSION_PREFIX=llonebot

# Bridge runtime
# aiohttp 会话的 HTTP 请求超时（秒）。
REQUEST_TIMEOUT_SEC=200
# OneBot WS 重连基础等待（秒）。
RECONNECT_DELAY_SEC=3
# 指数退避重连最大等待（秒）。
MAX_RECONNECT_DELAY_SEC=30
# 消息处理最大并发任务数。
MAX_CONCURRENCY=3
# 私聊配对门禁（开启后必须先配对才能调用 OpenClaw）。
PRIVATE_REQUIRE_PAIRING=true
# 配对码长度（有效范围：4~12）。
PRIVATE_PAIRING_CODE_LEN=8
# 配对码有效期（秒）。
PRIVATE_PAIRING_TTL_SEC=3600
# 已配对私聊 user_id 的持久化文件路径。
PRIVATE_PAIRING_STORE_PATH=./.bridge_private_pairing_users.json
# 每个会话缓存的观察消息上限（超过会裁剪）。
CONTEXT_OBSERVATION_LIMIT=30
# 单次构造 prompt 时最多带入的历史观察条数。
CONTEXT_FLUSH_LIMIT=12
# 单次请求最多携带的图片附件数。
MAX_IMAGE_ATTACHMENTS=3
# 单张图片最大下载字节数。
MAX_IMAGE_DOWNLOAD_BYTES=6291456
# 模型图片能力探测缓存有效期（秒）。
IMAGE_MODEL_PROBE_TTL_SEC=300

# Group behavior
# 为 true 时，群消息必须 @机器人（或命中前缀）才触发。
GROUP_REQUIRE_AT=true
# 群聊触发前缀（例如 /ai）。
GROUP_PREFIX=/ai
# 为 true 时，群回复会自动 @发送者。
GROUP_REPLY_AT_SENDER=false

# Optional
# 机器人自身 QQ 号（可选；有助于 @ 识别）。
BOT_SELF_QQ=
# 日志级别：DEBUG/INFO/WARNING/ERROR。
LOG_LEVEL=INFO
